#!/bin/bash

set -e

source ~/.dotfiles.env

if ! pyenv root > /dev/null 2>&1; then
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"

    eval "$(pyenv init --path)"
    eval "$(pyenv init -)"
fi

THIS_DIR="$(dirname "$0")"
FAILED_NOTIFICATIONS_DIR="$DOTFILES_HOME/tmp/notifications"
IS_RETRYING="${IS_RETRYING:-false}"

main() {
    if [[ "$#" -eq 0 ]]; then
        echo "Usage: echo 'Message body' | $0 <SUBJECT> [ATTACHMENTS...]" >&2
        exit 1
    fi

    local subject="$1"

    if [[ -z "$subject" ]]; then
        echo "Subject cannot be empty." >&2
        exit 1
    fi

    local body
    if [[ ! -t 0 ]]; then
        body="$(cat)"
    else
        body=''
    fi

    shift
    local attachments=("$@")

    echo "$body" | send_telegram "$subject" "${attachments[@]}" &

    # TODO: Fix email sending authentication failure.
    if [[ "$DOTFILES_CONFIG_EMAIL_NOTIFICATION" = 'true' ]]; then
        echo "$body" | send_email "$subject" &
    fi

    wait
}

send_telegram() {
    local subject="$1"
    local body="$(cat)"
    shift
    local attachments=("$@")

    if echo "$body" | "$THIS_DIR/send-notification-telegram" "$subject" "${attachments[@]}"; then
        echo "Telegram notification is sent."
    else
        echo "Failed to send telegram notification."
        echo "$body" | on_failure "$subject" "${attachments[@]}"
    fi
}

send_email() {
    local subject="$1"
    local body="$(cat)"

    if echo "$body" | "$THIS_DIR/send-notification-email" "$subject"; then
        echo "Email is sent."
    else
        echo "Failed to send email."
        echo "$body" | on_failure "$subject"
    fi
}

on_failure() {
    if [[ "$IS_RETRYING" = 'true' ]]; then
        return
    fi

    local subject="$1"
    local body="$(cat)"
    shift
    local attachments=("$@")
    local attachment_count="${#attachments[@]}"

    local timestamp="$(date -Iseconds)"

    local filename="$timestamp ${subject//\//%}.txt"
    local message_path="$FAILED_NOTIFICATIONS_DIR/$filename"

    local new_subject="$subject [RESEND $timestamp]"

    if [[ "$attachment_count" -gt 0 ]]; then
        new_subject="$new_subject [with $attachment_count missing attachments]"
    fi

    mkdir -pv "$(dirname "$message_path")"
    {
        echo "${SEND_NOTIFICATION_PROFILE:-}"
        echo "$new_subject"
        echo "$body"
    } > "$message_path"

    echo "Failed notification message is saved to: $message_path" >&2
}

main "$@"
